# Database (SQLite for dev, switch to PostgreSQL for production)
# DATABASE_URL=postgresql+asyncpg://clipflow:clipflow@localhost:5432/clipflow
DATABASE_URL=sqlite+aiosqlite:///clipflow.db

# JWT Secret
SECRET_KEY=change-me-to-a-random-string

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Whisper.cpp paths
WHISPER_CPP_PATH=./whisper.cpp/main
WHISPER_MODEL_PATH=./whisper.cpp/models/ggml-base.en.bin

# FFmpeg
FFMPEG_PATH=ffmpeg

# CORS
CORS_ORIGINS=http://localhost:3000
